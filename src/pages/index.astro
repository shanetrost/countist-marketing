---
import Layout from '../layouts/Layout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Countist",
    "url": "https://countist.app",
    "logo": "https://countist.app/images/countist-logo-6.png",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "countist@structurl.io",
      "contactType": "customer support"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Countist",
    "description": "AI-powered subscription tracker that identifies what you're overpaying, detects overlapping services, and keeps every renewal date visible — without connecting to your bank.",
    "url": "https://countist.app",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": [
      {
        "@type": "Offer",
        "name": "Monthly Plan",
        "price": "4.99",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
      },
      {
        "@type": "Offer",
        "name": "Annual Plan",
        "price": "49",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
      }
    ],
    "featureList": [
      "AI price anomaly detection",
      "Subscription overlap detection",
      "Calendar view of all renewal dates",
      "Data export",
      "No bank connection required",
      "Duplicate subscription alerts"
    ]
  }
];
---

<Layout
  title="Countist — Subscription Tracker | Save Money Without Connecting Your Bank"
  description="Track every subscription, catch duplicates, compare prices with AI, and see every renewal date in one calendar. No bank connection required. $4.99/month."
  canonical="https://countist.app/"
  ogImage="https://countist.app/images/og-home.png"
  jsonLd={jsonLd}
  currentPath="/"
>

  <!-- ========== 1. HERO ========== -->
  <section class="section_main-hero background-color-secondary">
    <div class="padding-global">
      <div class="w-layout-blockcontainer container-large w-container">
        <div class="hero-centered">
          <h1 class="heading-style-h1 text-align-center hero-heading">Take control of every dollar you spend on subscriptions</h1>
          <p class="text-align-center hero-subtext">
            Know exactly what you're paying for, find opportunities to save,<br class="hero-br" />
            and keep your money working for you, all without connecting your bank account.
          </p>
          <div class="hero-illustration">
            <img
              src="/images/header-main.png"
              loading="eager"
              alt="Person being pulled by subscriptions — illustration"
              style="width:100%;display:block;"
            />
          </div>
          <div class="button-group" style="justify-content:center;">
            <a data-wf--button--variant="primary" href="https://app.countist.app/join" class="button w-inline-block">
              <div class="button_text-large"><div>Get started – $4.99/month</div></div>
            </a>
            <a href="https://app.countist.app/join" class="button button-outline-orange w-inline-block">
              <div class="button_text-large"><div>Try free for 14 days</div></div>
            </a>
          </div>
          <p class="hero-fine-print">Credit card required. Cancel anytime during your trial. No charge until day 15.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 1b. APP SCREENSHOT ========== -->
  <section class="section_app-preview background-color-secondary">
    <div class="padding-global" style="padding-top:0;padding-bottom:0;">
      <div class="w-layout-blockcontainer container-large w-container">
        <div class="app-preview-frame">
          <img
            src="/images/app-screengrab.png"
            loading="eager"
            alt="Countist dashboard showing subscription totals, Smart Tips, Upcoming Payments, and Spending by Category"
            class="app-preview-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 2. TRUSTED BY ========== -->
  <section class="section_client-logos background-color-secondary">
    <div class="padding-global" style="padding-top:0.75rem;padding-bottom:1.25rem;">
      <div class="w-layout-blockcontainer container-small w-container">
        <div class="client-logos_wrapper">
          <h2 class="heading-style-h5 text-align-center" style="margin-bottom:0.875rem;">Trusted by subscribers and businesses:</h2>
          <div style="display:flex;align-items:center;justify-content:center;gap:4rem;flex-wrap:wrap;">
            <img src="/images/endorsed-logos-1.png" loading="lazy" alt="" style="height:3rem;opacity:0.55;filter:grayscale(1);" />
            <img src="/images/endorsed-logos-2.png" loading="lazy" alt="MTBPriceAgent" style="height:3rem;opacity:0.55;filter:grayscale(1);" />
            <img src="/images/endorsed-logos-3.png" loading="lazy" alt="" style="height:3rem;opacity:0.55;filter:grayscale(1);" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 3. STATS ========== -->
  <section class="section_stats">
    <div class="padding-global padding-section-large">
      <div class="w-layout-blockcontainer container-large w-container">

        <!-- Badge + Title -->
        <div class="stats-top fade-in-bottom">
          <div class="badge"><div class="badge_text"><div>Stats</div></div></div>
          <h2 class="heading-style-h2 text-align-center stats-heading">Most people spend $200+<br/>monthly on subscriptions</h2>
        </div>

        <!-- Illustrations flanking the subtitle -->
        <div class="stats-subtitle-row fade-in-bottom">
          <div class="stats-illust-col stats-illust-col--left">
            <img src="/images/illust-left.png" loading="lazy" alt="" class="stats-illust" />
          </div>
          <p class="stats-subtitle-text">
            The average person tracks 12+ subscriptions across streaming, productivity, fitness, and shopping. Many have duplicate services or features they don't realize they're paying for.
          </p>
          <div class="stats-illust-col stats-illust-col--right">
            <img src="/images/ilust-right.png" loading="lazy" alt="" class="stats-illust" />
          </div>
        </div>

        <!-- Stat cards -->
        <div class="stats-cards fade-in-bottom">

          <!-- 89% -->
          <div class="stat-card">
            <div class="stat-chart" aria-hidden="true">
              <svg viewBox="0 0 220 220" width="180" height="180">
                <!-- gray slice (11%) -->
                <path d="M 110 20 A 90 90 0 0 0 52.6 40.7 L 110 110 Z" fill="#DDD6CE"/>
                <!-- orange slice (89%) -->
                <path d="M 52.6 40.7 A 90 90 0 1 0 110 20 L 110 110 Z" fill="#E8603A"/>
              </svg>
            </div>
            <div class="stat-number">89%</div>
            <p class="stat-desc">Percent of consumers who underestimate how much they spend on subscriptions.</p>
          </div>

          <!-- 42% -->
          <div class="stat-card">
            <div class="stat-chart" aria-hidden="true">
              <svg viewBox="0 0 220 220" width="180" height="180">
                <!-- gray slice (58%) -->
                <path d="M 110 20 A 90 90 0 1 0 153.4 188.9 L 110 110 Z" fill="#DDD6CE"/>
                <!-- orange slice (42%) -->
                <path d="M 153.4 188.9 A 90 90 0 0 0 110 20 L 110 110 Z" fill="#E8603A"/>
              </svg>
            </div>
            <div class="stat-number">42%</div>
            <p class="stat-desc">Percent of consumers who admit to forgetting a subscription and continuing to pay for it.</p>
          </div>

          <!-- +2.5x — before/after comparison chart -->
          <div class="stat-card">
            <div class="stat-chart" aria-hidden="true">
              <svg viewBox="0 0 200 175" width="180" height="180">
                <!-- Baseline -->
                <line x1="18" y1="148" x2="182" y2="148" stroke="#C4B8B0" stroke-width="1.5"/>
                <!-- Bar 1: Estimate (short, gray) -->
                <rect x="34" y="108" width="52" height="40" rx="7" fill="#D4CAC2"/>
                <!-- Bar 2: Actual (2.5× taller, orange) -->
                <rect x="114" y="48" width="52" height="100" rx="7" fill="#E8603A"/>
                <!-- Dashed reference line at top of estimate bar -->
                <line x1="86" y1="108" x2="114" y2="108" stroke="#B0A89E" stroke-width="1.5" stroke-dasharray="3 2.5"/>
                <!-- Bar labels -->
                <text x="60"  y="163" text-anchor="middle" font-size="10.5" fill="#8a7f76" font-family="system-ui,sans-serif">Estimate</text>
                <text x="140" y="163" text-anchor="middle" font-size="10.5" fill="#8a7f76" font-family="system-ui,sans-serif">Actual</text>
              </svg>
            </div>
            <div class="stat-number">+2.5x</div>
            <p class="stat-desc">Amount that actual subscription costs exceed subscribers' estimates.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ========== 4. FEATURES MEDIUM (3 cards) ========== -->
  <section class="section_features-medium">
    <div class="padding-global padding-section-large">
      <div class="w-layout-blockcontainer container-large fade-in-bottom w-container">
        <div class="features-medium">
          <div class="section-heading max-width-large">
            <div class="section-heading_badge">
              <div class="badge"><div class="badge_text"><div>Features</div></div></div>
            </div>
            <h2 class="heading-style-h2 text-align-center">Everything you need to stay in control</h2>
            <p class="text-size-medium text-color-secondary text-align-center">
              Countist tracks your subscriptions, surfaces what's costing you more than it should, and keeps you ahead of every renewal date.
            </p>
          </div>
          <div class="w-layout-grid features-medium_grid">
            <div class="feature-medium">
              <div class="features-medium_image aspect-ratio-square">
                <img src="/images/ai-price-check-overlap-detection-title.png" loading="lazy"
                  alt="Countist detecting a duplicate Netflix subscription and Netflix/Amazon Prime overlap" />
              </div>
              <div class="features-medium_heading">
                <h3 class="heading-style-h4 features-1">AI Price Check and Overlap Detection</h3>
                <p class="text-size-regular text-color-secondary">Our AI Agent spots subscriptions where you're paying more than the current rate and finds overlapping services so you can cut what you don't need.</p>
              </div>
            </div>
            <div class="feature-medium">
              <div class="features-medium_image aspect-ratio-square">
                <img src="/images/privacy-first-title.png" loading="lazy"
                  alt="Countist Add New Subscription form — manual entry, no bank connection required" />
              </div>
              <div class="features-medium_heading">
                <h3 class="heading-style-h4 features-1">Privacy-First</h3>
                <p class="text-size-regular text-color-secondary">We don't connect your bank accounts. Enter subscriptions manually to keep your banking credentials completely private — no Plaid, no read access.</p>
              </div>
            </div>
            <div class="feature-medium">
              <div class="features-medium_image aspect-ratio-square">
                <img src="/images/calendar-view-title.png" loading="lazy"
                  alt="Countist calendar view showing Adobe Stock, Netflix, Midjourney, Spectrum, and Descript renewal dates" />
              </div>
              <div class="features-medium_heading">
                <h3 class="heading-style-h4 features-1">Calendar View</h3>
                <p class="text-size-regular text-color-secondary">Plan your subscriptions with confidence. See every upcoming renewal date at a glance so you're never hit with a surprise charge again.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 5. FEATURES SMALL (6 detail cards + CTA) ========== -->
  <section class="section_features-small">
    <div class="padding-global padding-section-large">
      <div class="w-layout-blockcontainer container-large fade-in-bottom w-container">
        <div class="section-heading max-width-large">
          <div class="section-heading_badge">
            <div class="badge"><div class="badge_text"><div>Tools</div></div></div>
          </div>
          <h2 class="heading-style-h2 text-align-center">A broad, intelligent feature set that saves you money</h2>
          <p class="text-size-medium text-color-secondary text-align-center">
            Tracking everything you pay for monthly and annually. Everything you need to know what's happening to your money. AI that actually earns its keep.
          </p>
        </div>
        <img
          src="/images/tool-row.png"
          loading="eager"
          alt=""
          aria-hidden="true"
          style="width:55%;display:block;margin:1.5rem auto;"
        />
        <!-- 6-item feature card grid -->
        <div class="features-small">
          <div class="w-layout-grid features-small_grid">
            <div class="features-small_item">
              <div class="hero-icon">
                <div class="icon-1x1-medium w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M14 4.4375C15.3462 4.4375 16.4375 3.34619 16.4375 2H17.5625C17.5625 3.34619 18.6538 4.4375 20 4.4375V5.5625C18.6538 5.5625 17.5625 6.65381 17.5625 8H16.4375C16.4375 6.65381 15.3462 5.5625 14 5.5625V4.4375ZM1 11C4.31371 11 7 8.31371 7 5H9C9 8.31371 11.6863 11 15 11V13C11.6863 13 9 15.6863 9 19H7C7 15.6863 4.31371 13 1 13V11ZM17.25 14C17.25 15.7949 15.7949 17.25 14 17.25V18.75C15.7949 18.75 17.25 20.2051 17.25 22H18.75C18.75 20.2051 20.2051 18.75 22 18.75V17.25C20.2051 17.25 18.75 15.7949 18.75 14H17.25Z"/></svg>
                </div>
              </div>
              <div class="features-small_heading">
                <h3 class="heading-style-h4">AI Price Check</h3>
                <p class="text-size-regular text-color-secondary">You can manage your subscriptions individually and do a price check so you always know if you're paying more than you should for your plan.</p>
              </div>
            </div>
            <div class="features-small_item">
              <div class="hero-icon">
                <div class="icon-1x1-medium w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L20 5V11C20 16.5228 16.5228 21 12 22C7.47715 21 4 16.5228 4 11V5L12 1ZM12 3.2315L6 6.3315V11C6 15.3416 8.70842 18.9908 12 20.0659C15.2916 18.9908 18 15.3416 18 11V6.3315L12 3.2315Z"/></svg>
                </div>
              </div>
              <div class="features-small_heading">
                <h3 class="heading-style-h4">Zero-Party Data</h3>
                <p class="text-size-regular text-color-secondary">You manage your subscription data by entering it yourself so we are never a possible security breach for your financial accounts. Completely private.</p>
              </div>
            </div>
            <div class="features-small_item">
              <div class="hero-icon">
                <div class="icon-1x1-medium w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11 2C15.968 2 20 6.032 20 11C20 15.968 15.968 20 11 20C6.032 20 2 15.968 2 11C2 6.032 6.032 2 11 2ZM11 4C7.13401 4 4 7.13401 4 11C4 14.866 7.13401 18 11 18C14.866 18 18 14.866 18 11C18 7.13401 14.866 4 11 4ZM19.4853 18.0711L22.3137 20.8995L20.8995 22.3137L18.0711 19.4853L19.4853 18.0711Z"/></svg>
                </div>
              </div>
              <div class="features-small_heading">
                <h3 class="heading-style-h4">Duplicate Check</h3>
                <p class="text-size-regular text-color-secondary">When you add a subscription, we will automatically scan for duplicates. Alternatively, you can do a manual search for duplicates at any time.</p>
              </div>
            </div>
            <div class="features-small_item">
              <div class="hero-icon">
                <div class="icon-1x1-medium w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11 2.04938V13H21.9506C21.4489 18.0533 17.1853 22 12 22C6.47715 22 2 17.5229 2 12C2 6.81465 5.94668 2.5511 11 2.04938ZM13 2.04938C17.7244 2.51845 21.4816 6.27559 21.9506 11H13V2.04938Z"/></svg>
                </div>
              </div>
              <div class="features-small_heading">
                <h3 class="heading-style-h4">Price Check</h3>
                <p class="text-size-regular text-color-secondary">You can do a price check across all of your subscriptions at any time, and we'll tell you right then if you're paying more than the current advertised rate.</p>
              </div>
            </div>
            <div class="features-small_item">
              <div class="hero-icon">
                <div class="icon-1x1-medium w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3H21C21.5523 3 22 3.44772 22 4V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2.44772 3 3 3ZM12 10.5858L5.92893 4.51472L4.51472 5.92893L10.5858 12L4.51472 18.0711L5.92893 19.4853L12 13.4142L18.0711 19.4853L19.4853 18.0711L13.4142 12L19.4853 5.92893L18.0711 4.51472L12 10.5858Z"/></svg>
                </div>
              </div>
              <div class="features-small_heading">
                <h3 class="heading-style-h4">Overlap Check</h3>
                <p class="text-size-regular text-color-secondary">We check for, and notify you of, any subscription overlap — services that do the same thing so you can eliminate ones you're paying for twice.</p>
              </div>
            </div>
            <div class="features-small_item">
              <div class="hero-icon">
                <div class="icon-1x1-medium w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M8.49816 20.0048H15.5018C14.8432 21.5842 13.5794 22.848 12 23.5066C10.4206 22.848 9.15679 21.5842 8.49816 20.0048ZM18 14.8095L20 17.0778V19.0048H4V17.0778L6 14.8095V9.00481C6 5.52156 8.50442 2.55825 12 1.46002C15.4956 2.55825 18 5.52156 18 9.00481V14.8095ZM12 11.0048C13.1046 11.0048 14 10.1094 14 9.00481C14 7.90024 13.1046 7.00481 12 7.00481C10.8954 7.00481 10 7.90024 10 9.00481C10 10.1094 10.8954 11.0048 12 11.0048Z"/></svg>
                </div>
              </div>
              <div class="features-small_heading">
                <h3 class="heading-style-h4">Forgotten Accounts</h3>
                <p class="text-size-regular text-color-secondary">Countist will remind you of subscriptions you haven't logged into recently — so you can decide if it's still worth keeping before your next billing cycle.</p>
              </div>
            </div>
          </div>
          <div class="button-group" style="justify-content:center;margin-top:3rem;">
            <a data-wf--button--variant="primary" href="https://app.countist.app/join" class="button w-inline-block">
              <div class="button_text-large"><div>Start free trial</div></div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 6. PRICING ========== -->
  <section class="section_plans background-color-secondary">
    <div class="padding-global padding-section-large">
      <div class="w-layout-blockcontainer container-large fade-in-bottom w-container">
        <div class="plans">
          <div class="section-heading max-width-large">
            <div class="section-heading_badge">
              <div class="badge"><div class="badge_text"><div>Plans</div></div></div>
            </div>
            <h2 class="heading-style-h2 text-align-center">Supercharge Your Budget</h2>
            <p class="text-size-medium text-color-secondary text-align-center">
              Simple pricing. No feature tiers. Everything included. Cancel anytime.
            </p>
          </div>
          <img
            src="/images/super-charge.png"
            loading="lazy"
            alt=""
            aria-hidden="true"
            style="width:100%;display:block;margin:-2rem auto -3rem;"
          />
          <div class="w-layout-grid plans_grid">

            <!-- Free Trial -->
            <div class="plans_item">
              <div class="plans_inner">
                <div class="plans_heading">
                  <h3 class="heading-style-h4">Free Trial</h3>
                  <p class="text-size-regular text-color-secondary">No credit card required. Full access for 14 days.</p>
                </div>
                <div class="plans_price">
                  <div class="heading-style-h2">$0</div>
                  <div class="text-size-regular text-color-secondary">/14 days</div>
                </div>
                <div class="text-size-small text-color-secondary" style="margin-top:-0.5rem;margin-bottom:0.5rem;">Then $4.99/mo if you continue</div>
                <div class="horizontal-divider"></div>
                <ul role="list" class="plans_features-list">
                  <li class="plans_list-item">
                    <div class="icon-1x1-medium w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" viewBox="0 0 24 25" fill="none"><circle cx="12" cy="12.417" r="10" fill="#FF592C"/><path fill-rule="evenodd" clip-rule="evenodd" d="M2 12.417C2 17.9399 6.47715 22.417 12 22.417C17.5229 22.417 22 17.9399 22 12.417C22 6.89415 17.5229 2.41699 12 2.41699C6.47715 2.41699 2 6.89415 2 12.417ZM16.3495 8.94057C16.7282 9.28773 16.7538 9.87616 16.4067 10.2549L11.2904 15.8362C11.1189 16.0233 10.8785 16.1322 10.6248 16.1377C10.3712 16.1432 10.1263 16.0449 9.94687 15.8655L7.62129 13.5399C7.25802 13.1766 7.25802 12.5876 7.62129 12.2243C7.98458 11.8611 8.57356 11.8611 8.93685 12.2243L10.5754 13.8629L15.0352 8.99772C15.3823 8.619 15.9708 8.59342 16.3495 8.94057Z" fill="#FFF3ED"/></svg></div>
                    <div class="text-size-regular">All features</div>
                  </li>
                  <li class="plans_list-item">
                    <div class="icon-1x1-medium w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" viewBox="0 0 24 25" fill="none"><circle cx="12" cy="12.417" r="10" fill="#FF592C"/><path fill-rule="evenodd" clip-rule="evenodd" d="M2 12.417C2 17.9399 6.47715 22.417 12 22.417C17.5229 22.417 22 17.9399 22 12.417C22 6.89415 17.5229 2.41699 12 2.41699C6.47715 2.41699 2 6.89415 2 12.417ZM16.3495 8.94057C16.7282 9.28773 16.7538 9.87616 16.4067 10.2549L11.2904 15.8362C11.1189 16.0233 10.8785 16.1322 10.6248 16.1377C10.3712 16.1432 10.1263 16.0449 9.94687 15.8655L7.62129 13.5399C7.25802 13.1766 7.25802 12.5876 7.62129 12.2243C7.98458 11.8611 8.57356 11.8611 8.93685 12.2243L10.5754 13.8629L15.0352 8.99772C15.3823 8.619 15.9708 8.59342 16.3495 8.94057Z" fill="#FFF3ED"/></svg></div>
                    <div class="text-size-regular">Unlimited subscriptions</div>
                  </li>
                  <li class="plans_list-item">
                    <div class="icon-1x1-medium w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" viewBox="0 0 24 25" fill="none"><circle cx="12" cy="12.417" r="10" fill="#FF592C"/><path fill-rule="evenodd" clip-rule="evenodd" d="M2 12.417C2 17.9399 6.47715 22.417 12 22.417C17.5229 22.417 22 17.9399 22 12.417C22 6.89415 17.5229 2.41699 12 2.41699C6.47715 2.41699 2 6.89415 2 12.417ZM16.3495 8.94057C16.7282 9.28773 16.7538 9.87616 16.4067 10.2549L11.2904 15.8362C11.1189 16.0233 10.8785 16.1322 10.6248 16.1377C10.3712 16.1432 10.1263 16.0449 9.94687 15.8655L7.62129 13.5399C7.25802 13.1766 7.25802 12.5876 7.62129 12.2243C7.98458 11.8611 8.57356 11.8611 8.93685 12.2243L10.5754 13.8629L15.0352 8.99772C15.3823 8.619 15.9708 8.59342 16.3495 8.94057Z" fill="#FFF3ED"/></svg></div>
                    <div class="text-size-regular">Full AI insights</div>

---
import Layout from '../layouts/Layout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact Countist",
    "url": "https://countist.app/contact",
    "description": "Get in touch with the Countist team for support, feature requests, bug reports, or general questions.",
    "mainEntity": {
      "@type": "Organization",
      "name": "Countist",
      "email": "countist@structurl.io",
      "url": "https://countist.app"
    }
  }
];
---

<Layout
  title="Contact — Get Subscription Clarity Today — Countist Subscription Tracker"
  description="Questions about Countist? Need help with your account? Found a bug? Email countist@structurl.io — we respond within 24 hours on business days."
  canonical="https://countist.app/contact"
  ogImage="https://countist.app/images/og-contact.png"
  jsonLd={jsonLd}
  currentPath="/contact"
>
  <!-- HERO -->
  <section class="section_main-hero background-color-secondary">
    <div class="padding-global padding-section-large">
      <div class="w-layout-blockcontainer container-small fade-in-bottom w-container" style="text-align:center;">
        <div class="badge" style="margin-bottom:1rem;display:inline-flex;"><div class="badge_text"><div>Get In Touch</div></div></div>
        <h1 class="heading-style-h1">What's On Your Mind?</h1>
        <p class="text-size-medium text-color-secondary" style="margin:1.5rem auto 0;max-width:36rem;">
          Have a question about the service? Need help with your account? Found a bug? Have a feature suggestion? We respond to all messages within 24 hours on business days.
        </p>
        <div style="margin-top:2rem;">
          <a
            href="mailto:countist@structurl.io?subject=Question%20about%20Countist"
            data-wf--button--variant="primary"
            class="button w-inline-block"
          >
            <div class="button_text-large"><div>Email us</div></div>
          </a>
          <p class="text-size-small text-color-secondary" style="margin-top:0.75rem;">
            <a href="mailto:countist@structurl.io" style="text-decoration:underline;">COUNTIST@STRUCTURL.IO</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ QUICK LIST -->
  <section class="section_faq background-color-secondary">
    <div class="padding-global padding-section-large">
      <div class="w-layout-blockcontainer container-small fade-in-bottom w-container">
        <div class="section-heading max-width-large" style="margin-bottom:2.5rem;">
          <div class="badge" style="margin-bottom:1rem;"><div class="badge_text"><div>Quick Answers</div></div></div>
          <h2 class="heading-style-h2 text-align-center">Common questions</h2>
        </div>
        <div class="faq">
          <div class="faq_list">
            {[
              {
                q: "Do I have to connect my bank account?",
                a: "No. Countist never requires bank connections. You add subscriptions manually in about 30 seconds each. Complete control, complete privacy."
              },
              {
                q: "What happens after my free trial?",
                a: "After 14 days you'll be charged $4.99/month unless you cancel. Cancel anytime before day 15 and you won't be charged anything."
              },
              {
                q: "Is my data private?",
                a: "Yes. Your data is never sold, shared, or used for advertising. We don't connect to your bank and we don't share your data with third parties."
              },
              {
                q: "Can I cancel anytime?",
                a: "Yes. Cancel from your account settings at any time. If you cancel mid-period, you keep access until the end of that billing period."
              },
            ].map(({ q, a }) => (
              <details class="faq_item">
                <summary>
                  <h3 class="heading-style-h5" style="margin:0;">{q}</h3>
                  <span class="faq_icon-plus">+</span>
                </summary>
                <div class="faq_answer-text">
                  <p class="text-size-regular text-color-secondary">{a}</p>
                </div>
              </details>
            ))}
          </div>
          <div style="text-align:center;margin-top:2rem;">
            <a href="/faqs" class="footer_menu_link w-inline-block">See all FAQs →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

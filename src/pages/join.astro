---
import Layout from '../layouts/Layout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Start Your Free Trial — Countist",
    "description": "Start your 14-day free trial of Countist. Track all your subscriptions, detect duplicates, and spot AI-identified price anomalies. No bank connection. No charge until day 15.",
    "url": "https://countist.app/join"
  }
];

const features = [
  "Unlimited subscription tracking",
  "AI price anomaly detection",
  "Overlap and duplicate detection",
  "Calendar view of all renewal dates",
  "Personalized smart tips",
  "Data export anytime",
  "Cancel before day 15 — pay nothing",
];
---

<Layout
  title="Start Your Free Trial — Countist Subscription Tracker"
  description="Start your 14-day free trial of Countist. Track all your subscriptions, detect duplicates, and spot AI-identified price anomalies. No bank connection. No charge until day 15."
  canonical="https://countist.app/join"
  ogImage="https://countist.app/images/og-home.png"
  jsonLd={jsonLd}
  currentPath="/join"
>

  <!-- HERO -->
  <section class="section_main-hero background-color-secondary">
    <div class="padding-global padding-section-large" style="padding-bottom:2rem !important;">
      <div class="w-layout-blockcontainer container-small w-container">
        <div class="section-heading max-width-large fade-in-bottom" style="text-align:center;">
          <div class="badge" style="margin-bottom:1.25rem;"><div class="badge_text"><div>Free 14-Day Trial</div></div></div>
          <h1 class="heading-style-h1 text-align-center">Start Saving on Subscriptions</h1>
          <p class="text-size-large text-color-secondary text-align-center" style="color: var(--color--accent--400, #ff592c);">
            No bank connection. No charge until day 15. Cancel anytime.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA CARD -->
  <section class="section_join background-color-secondary">
    <div class="padding-global padding-section-large" style="padding-top:0 !important;">
      <div class="w-layout-blockcontainer container-small fade-in-bottom w-container">
        <div class="join-card">
          <div class="join-card_inner">

            <div class="join-card_heading">
              <div class="plans_price">
                <div class="heading-style-h2">$0</div>
                <div class="text-size-regular text-color-secondary">/14 days</div>
              </div>
              <div class="text-size-small text-color-secondary">Then $4.99/month or $49/year — cancel before day 15 to pay nothing</div>
            </div>

            <div class="horizontal-divider"></div>

            <ul role="list" class="plans_features-list">
              {features.map(f => (
                <li class="plans_list-item">
                  <div class="icon-1x1-medium w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" viewBox="0 0 24 25" fill="none"><circle cx="12" cy="12.417" r="10" fill="#FF592C"/><path fill-rule="evenodd" clip-rule="evenodd" d="M2 12.417C2 17.9399 6.47715 22.417 12 22.417C17.5229 22.417 22 17.9399 22 12.417C22 6.89415 17.5229 2.41699 12 2.41699C6.47715 2.41699 2 6.89415 2 12.417ZM16.3495 8.94057C16.7282 9.28773 16.7538 9.87616 16.4067 10.2549L11.2904 15.8362C11.1189 16.0233 10.8785 16.1322 10.6248 16.1377C10.3712 16.1432 10.1263 16.0449 9.94687 15.8655L7.62129 13.5399C7.25802 13.1766 7.25802 12.5876 7.62129 12.2243C7.98458 11.8611 8.57356 11.8611 8.93685 12.2243L10.5754 13.8629L15.0352 8.99772C15.3823 8.619 15.9708 8.59342 16.3495 8.94057Z" fill="#FFF3ED"/></svg></div>
                  <div class="text-size-regular">{f}</div>
                </li>
              ))}
            </ul>

            <a href="https://app.countist.app/join" data-wf--button--variant="primary" class="button w-inline-block" style="width:100%;justify-content:center;">
              <div class="button_text-large"><div>Try free for 14 days</div></div>
            </a>

            <p class="text-size-small text-color-secondary" style="text-align:center;margin-top:0.25rem;">
              No credit card required to start
            </p>

          </div>
        </div>

        <p class="text-size-small text-color-secondary" style="text-align:center;margin-top:1.5rem;">
          Already have an account? <a href="https://app.countist.app" style="color:var(--color--accent--400,#ff592c);text-decoration:underline;">Sign in</a>
        </p>
      </div>
    </div>
  </section>

</Layout>

<style>
  .join-card {
    border-radius: 1rem;
    border: 2px solid #ff592c;
    background: #fff;
    overflow: hidden;
    max-width: 480px;
    margin: 0 auto;
  }
  .join-card_inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .join-card_heading {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .plans_price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .horizontal-divider {
    height: 1px;
    background: var(--border-color--border-primary, #e8e8e8);
    margin: 0.25rem 0;
  }
  .plans_features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .plans_list-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .plans_list-item .icon-1x1-medium {
    flex-shrink: 0;
    margin-top: 0.125rem;
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Terms of Service — Countist Subscription Tracker"
  description="Countist terms of service. Use of the Countist subscription tracking application."
  canonical="https://countist.app/terms"
  currentPath="/terms"
>
  <section class="section_main-hero background-color-secondary">
    <div class="padding-global padding-section-large">
      <div class="w-layout-blockcontainer container-small w-container">
        <div class="fade-in-bottom">
          <div class="badge" style="margin-bottom:1.25rem;"><div class="badge_text"><div>Legal</div></div></div>
          <h1 class="heading-style-h1">Terms of Service</h1>
          <p class="text-size-regular text-color-secondary" style="margin-top:0.5rem;">Last updated: May 2026</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section_faq">
    <div class="padding-global padding-section-large">
      <div class="w-layout-blockcontainer container-small fade-in-bottom w-container">
        <div style="max-width:65ch;">
          <p class="text-size-regular text-color-secondary" style="margin-bottom:2rem;">
            For our full terms of service, please contact us at <a href="mailto:countist@structurl.io" style="text-decoration:underline;">countist@structurl.io</a>. This page will be updated with the complete terms shortly.
          </p>
          <div style="margin-top:2.5rem;">
            <a href="mailto:countist@structurl.io?subject=Terms%20Question" data-wf--button--variant="secondary" class="button w-inline-block">
              <div class="button_text-large"><div>Email terms questions</div></div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

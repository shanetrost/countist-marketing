---
interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  jsonLd?: object | object[];
  currentPath?: string;
  googleVerification?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://countist.app/images/og-home.png',
  jsonLd,
  currentPath = '',
  googleVerification,
} = Astro.props;

const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Countist" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" href="/images/favicon-96x96.png" type="image/png" sizes="96x96" />
  <link rel="apple-touch-icon" href="/images/favicon-96x96.png" />

  {googleVerification && <meta name="google-site-verification" content={googleVerification} />}

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-WSP5GF5C');</script>
  <!-- End Google Tag Manager -->

  <!-- Mailchimp -->
  <script id="mcjs">!function(c,h,i,m,p){m=c.createElement(h),p=c.getElementsByTagName(h)[0],m.async=1,m.src=i,p.parentNode.insertBefore(m,p)}(document,"script","https://chimpstatic.com/mcjs-connected/js/users/d36f24c5dfaa3f2e5534959e8/da600ae895cb75a1ebb8235a8.js");</script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=BIZ+UDPMincho:wght@400;700&display=swap" rel="stylesheet" />

  <link href="/css/normalize.css" rel="stylesheet" />
  <link href="/css/webflow.css" rel="stylesheet" />
  <link href="/css/countist.css" rel="stylesheet" />

  {jsonLdArray && jsonLdArray.map((ld) => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}

  <style>
    /* ── Animations ── */
    .fade-in-bottom {
      opacity: 0;
      transform: translateY(2rem);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in-bottom.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .fade-in-bottom {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
    }

    /* ── FAQ accordion ── */
    .faq_item {
      border-bottom: 1px solid var(--border-color--border-primary, #e8e8e8);
    }
    .faq_item summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 0;
      gap: 1rem;
    }
    .faq_item summary::-webkit-details-marker { display: none; }
    .faq_icon-plus { font-size: 1.5rem; line-height: 1; flex-shrink: 0; transition: transform 0.2s ease; }
    .faq_item[open] .faq_icon-plus { transform: rotate(45deg); }
    .faq_answer-text { padding-bottom: 1.25rem; }

    @media (max-width: 767px) {
      .plans_grid { grid-template-columns: 1fr !important; }
    }

    .button-outline-orange {
      background: transparent !important;
      border: 1.5px solid var(--color--accent--400, #ff592c) !important;
      color: var(--color--accent--400, #ff592c) !important;
    }
    .button-outline-orange .button_text-large,
    .button-outline-orange .button_text-large div {
      color: var(--color--accent--400, #ff592c) !important;
    }
    .button-outline-orange:hover {
      background: rgba(255,89,44,0.06) !important;
    }

    .stats_grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      text-align: center;
    }
    @media (max-width: 767px) {
      .stats_grid { grid-template-columns: 1fr; gap: 2.5rem; }
    }
    .stats_number {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 700;
      color: var(--color--accent--400, #ff592c);
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    /* ══════════════════════════════════════════════════════════════
       NAV — scoped here so Astro's [data-astro-cid] attribute gives
       specificity (0,2,0) and beats Webflow's plain (0,1,0) rules
       without needing !important.
       ══════════════════════════════════════════════════════════════ */

    /* Fixed bar — transparent by default */
    .nav_component {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      overflow: visible;
      background-color: transparent;
      padding-top: 1.25rem;
      padding-bottom: 1.25rem;
      transition:
        top 0.42s cubic-bezier(0.34, 1.56, 0.64, 1),
        left 0.42s cubic-bezier(0.34, 1.56, 0.64, 1),
        right 0.42s cubic-bezier(0.34, 1.56, 0.64, 1),
        border-radius 0.42s cubic-bezier(0.34, 1.56, 0.64, 1),
        background-color 0.28s ease,
        box-shadow 0.28s ease;
      will-change: left, right, border-radius;
    }

    /* Floating pill after scroll */
    .nav_component.is-scrolled {
      top: 0.625rem;
      left: 1.25rem;
      right: 1.25rem;
      border-radius: 1rem;
      background-color: rgba(245, 244, 241, 0.95);
      backdrop-filter: blur(16px) saturate(1.4);
      -webkit-backdrop-filter: blur(16px) saturate(1.4);
      box-shadow: 0 6px 32px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.04);
    }

    /* 3-col row: [logo flex:1] [links shrink:0] [sign-in flex:1] */
    .nav_container--3col {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      width: 100%;
      max-width: 80rem;
      margin-left: auto;
      margin-right: auto;
      min-height: 3.75rem;
      box-sizing: border-box;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .nav_brand {
      flex: 1 1 0%;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      float: none;
      min-width: 0;
    }

    /* Reset Webflow's mobile full-screen nav properties */
    .nav_menu {
      flex-shrink: 0;
      position: static;
      float: none;
      height: auto;
      background: none;
      inset: unset;
      display: flex;
    }

    .nav_menu-inner--centered {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 2.5rem;
      height: auto;
    }

    .nav_menu_link {
      font-size: 1rem;
      font-weight: 400;
      padding: 0.25rem 0;
      display: inline-block;
      color: var(--color--netural--950, #1a1a1a);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav_menu_link:hover {
      color: var(--color--accent--400, #ff592c);
      text-decoration: underline;
    }
    .nav_menu_link.w--current { color: var(--color--accent--500, #d44a20); }

    .nav_end {
      flex: 1 1 0%;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 1rem;
      float: none;
      min-width: 0;
    }

    .nav_signin-link {
      color: var(--color--accent--400, #ff592c);
      font-size: 1rem;
      font-weight: 500;
      text-decoration: none;
      white-space: nowrap;
    }
    .nav_signin-link:hover { opacity: 0.8; }

    /* Hamburger hidden at desktop */
    .nav_button { display: none; }

    /* Offset content below fixed nav */
    .main-wrapper { padding-top: 7.5rem; }

    /* ── Mobile ── */
    @media (max-width: 991px) {
      .nav_menu { display: none; }
      .nav_menu.w--open {
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 4rem;
        left: 0;
        right: 0;
        inset: unset;
        height: auto;
        background: var(--background-color--background-secondary, #f5f0eb);
        padding: 1.5rem;
        z-index: 100;
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      }
      .nav_menu.w--open .nav_menu-inner--centered {
        flex-direction: column;
        gap: 0;
        align-items: flex-start;
      }
      .nav_button { display: flex; cursor: pointer; }
      .nav_component.is-scrolled {
        top: 0.5rem;
        left: 0.75rem;
        right: 0.75rem;
      }
      .main-wrapper { padding-top: 5.5rem; }
    }
  </style>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WSP5GF5C"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <div class="page-wrapper">
    <div class="global-styles w-embed">
      <style>body { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }</style>
    </div>

    <!-- NAV -->
    <div class="nav_component w-nav" role="banner">
      <div class="padding-global">
        <div class="nav_container nav_container--3col">
          <a href="/" class="nav_brand w-nav-brand" aria-label="Countist home">
            <img src="/images/countist-logo-6.png" loading="eager" width="160" alt="Countist" style="height:auto;display:block;" />
          </a>
          <nav role="navigation" class="nav_menu w-nav-menu">
            <div class="nav_menu-inner nav_menu-inner--centered">
              <a href="/pricing" class={`nav_menu_link w-nav-link${currentPath === '/pricing' ? ' w--current' : ''}`}>Pricing</a>
              <a href="/faqs" class={`nav_menu_link w-nav-link${currentPath === '/faqs' ? ' w--current' : ''}`}>FAQs</a>
              <a href="/contact" class={`nav_menu_link w-nav-link${currentPath === '/contact' ? ' w--current' : ''}`}>Contact</a>
            </div>
          </nav>
          <div class="nav_end">
            <a href="https://app.countist.app/sign-in" class="nav_signin-link">Sign In</a>
            <div class="nav_button w-nav-button" role="button" aria-label="Toggle navigation" tabindex="0">
              <div class="hamburger_6_wrap">
                <div class="hamburger_6_line"></div>
                <div class="hamburger_6_line"></div>
                <div class="hamburger_6_line"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <main class="main-wrapper">
      <slot />
    </main>

    <!-- FOOTER -->
    <section class="section_footer background-color-secondary">
      <div class="padding-global">
        <div class="w-layout-blockcontainer container-large w-container">
          <div class="footer">
            <div class="footer_cta">
              <div class="padding-top padding-xhuge fade-in-bottom">
                <div class="cta">
                  <div class="badge">
                    <div class="badge_text"><div>What's next?</div></div>
                  </div>
                  <div class="cta_heading text-align-center">
                    <h2 class="heading-style-h1 is-cta">Ready when you are. Start your free trial.</h2>
                  </div>
                  <div class="button-group">
                    <a data-wf--button--variant="primary" href="https://app.countist.app/join" class="button w-inline-block">
                      <div class="button_text-large"><div>Get Started</div></div>
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <div class="w-layout-grid footer_body">
              <div class="footer_logo-wrapper">
                <a href="https://www.councilforeconed.org/" target="_blank" rel="noopener noreferrer">
                  <img src="/images/CEE-logo2.png" alt="Council for Economic Education" style="height:52px;width:auto;opacity:0.5;filter:grayscale(1);display:block;margin-bottom:0.75rem;" />
                </a>
                <p class="text-size-small text-color-secondary" style="line-height:1.6;max-width:210px;">
                  We donate a portion of revenue to
                  <a href="https://www.councilforeconed.org/" target="_blank" rel="noopener noreferrer" style="text-decoration:underline;">financial literacy education</a>
                  through the Council for Economic Education.
                </p>
              </div>
              <div class="footer_nav">
                <div class="footer_column">
                  <div class="text-size-regular text-weight-medium">Product</div>
                  <ul role="list" class="footer_nav-links w-list-unstyled">
                    <li><a href="/pricing" class="footer_menu_link text-color-secondary w-inline-block"><div>Pricing</div></a></li>
                    <li><a href="/faqs" class="footer_menu_link w-inline-block"><div>FAQs</div></a></li>
                    <li><a href="/contact" class="footer_menu_link w-inline-block"><div>Contact</div></a></li>
                  </ul>
                </div>
                <div class="footer_column">
                  <div class="text-size-regular text-weight-medium">Legal</div>
                  <ul role="list" class="footer_nav-links w-list-unstyled">
                    <li><a href="/privacy" class="footer_menu_link w-inline-block"><div>Privacy Policy</div></a></li>
                    <li><a href="/terms" class="footer_menu_link w-inline-block"><div>Terms of Service</div></a></li>
                  </ul>
                </div>
                <div class="footer_column">
                  <div class="text-size-regular text-weight-medium">Contact</div>
                  <ul role="list" class="footer_nav-links w-list-unstyled">
                    <li>
                      <a href="mailto:countist@structurl.io" class="footer_menu_link w-inline-block">
                        <div>countist@structurl.io</div>
                      </a>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
            <div class="footer_copy">
              <div class="text-size-small text-color-secondary">© 2026 Countist. All rights reserved.</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Mobile nav toggle
      const navBtn = document.querySelector<HTMLElement>('.nav_button');
      const navMenu = document.querySelector<HTMLElement>('.nav_menu');

      navBtn?.addEventListener('click', () => {
        navBtn.classList.toggle('w--open');
        navMenu?.classList.toggle('w--open');
      });

      navMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          navBtn?.classList.remove('w--open');
          navMenu?.classList.remove('w--open');
        });
      });

      // Scroll-triggered fade animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.fade-in-bottom').forEach(el => observer.observe(el));

      // Scroll-triggered floating pill nav
      const navComponent = document.querySelector<HTMLElement>('.nav_component');
      let rafPending = false;
      const onScroll = () => {
        if (!rafPending) {
          rafPending = true;
          requestAnimationFrame(() => {
            navComponent?.classList.toggle('is-scrolled', window.scrollY > 60);
            rafPending = false;
          });
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
    });
  </script>
</body>
</html>
